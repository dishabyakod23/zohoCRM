PORT=5000
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/zoho_crm
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
NODE_ENV=development

# URL of the deployed frontend (for CORS), e.g. https://your-app.vercel.app
FRONTEND_URL=

# Set to false on free hosting tiers (cron may not run reliably)
ENABLE_WEEKLY_REPORTS=false
